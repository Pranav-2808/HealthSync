rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /trainers/{trainerId} {
      allow read, write: if request.auth != null && request.auth.uid == trainerId;

      match /members/{memberId} {
        allow read, write: if request.auth != null && request.auth.uid == trainerId;
      }
    }
  }
}
